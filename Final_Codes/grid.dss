Set DefaultBaseFrequency=50 

set datapath=C:\Main_Matlab 
clear

 !! new network
new circuit.sadu baseKv=20 angle=0 frequency=50 phases=3 MVAsc1=1e8 MVAsc3=1e8 x1r1=11.43 x0r0=4.138

set voltagebases=[20 0.69]
calcvoltagebases

!!transformer 

!!phase 1
new transformer.Dy11ph1 phases=1 windings=2
~ taps=[1, 1]
~ buses=[Sourcebus.1.2 PT1.1.4]
~ conns=[delta wye]
~ kvs=[20 (0.69 3 sqrt /)]
~ kvas=(210, 210)
~ Xhl=4.6 %noloadloss=0 %loadloss=0 
~ maxtap=1.1 mintap=0.9 numtap=10


!!phase 2
